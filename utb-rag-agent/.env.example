# ── Providers ──────────────────────────────────────────────
# "gemini" | "ollama"
LLM_PROVIDER=gemini
EMBED_PROVIDER=gemini

# ── Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyBw1qdqCR9tu5ovgjuFF5tEb8Upc0foczw
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-2

# ── Ollama (fallback offline) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG ─────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
COLLECTION_NAME=utb_docs
TOP_K=4
# Distancia coseno: 0.0 = idéntico, 2.0 = opuesto. Umbral de escalamiento:
ESCALATE_THRESHOLD=0.50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
